# VoxelCraft Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# JWT / Authentication
# =============================================================================
JWT_SECRET=change-me-to-a-random-string-at-least-32-bytes

# =============================================================================
# Database (Server)
# =============================================================================
DATABASE_URL=postgres://voxelcraft:voxelcraft@localhost:5432/voxelcraft

# =============================================================================
# Redis (Server + Matchmaking)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Game Server
# =============================================================================
SERVER_PORT=25565
SERVER_NAME=VoxelCraft Server
WORLD_SEED=0
MAX_PLAYERS=100
VIEW_DISTANCE=10
MATCHMAKING_URL=http://localhost:8080
RUST_LOG=info

# =============================================================================
# Matchmaking Service
# =============================================================================
MATCHMAKING_PORT=8080

# =============================================================================
# Client (single-player)
# =============================================================================
SINGLEPLAYER=false
SERVER_ADDRESS=localhost:25565
